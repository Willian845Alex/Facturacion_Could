# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=facturacion

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Redis / Memurai
REDIS_HOST=localhost
REDIS_PORT=6379

# AES-256 para certificado .p12
ENCRYPTION_KEY=

# SRI - 1=pruebas, 2=produccion
SRI_AMBIENTE=1

# SMTP — envío de facturas por email
# Para Gmail: activar "Contraseñas de aplicación" en la cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_gmail
SMTP_FROM="VITAL FARMA <facturacion@vitalfarma.com>"

# App
NODE_ENV=development
API_PORT=3000
FRONTEND_URL=http://localhost:5173
